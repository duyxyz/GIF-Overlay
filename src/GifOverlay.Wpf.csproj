<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>assets\app_icon.ico</ApplicationIcon>
    <AssemblyName>GIF-Overlay</AssemblyName>
    <Version>1.3.5</Version>
    <FileVersion>1.3.5</FileVersion>
    <Authors>DuyXYZ</Authors>
    <Company>DuyXYZ</Company>
    <Description>Minimalist GIF &amp; Image Viewer</Description>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="assets\app_icon.ico" />
    <Content Include="assets\demo1.gif">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MahApps.Metro.IconPacks.Material" Version="6.2.1" />
    <PackageReference Include="WpfAnimatedGif" Version="2.0.2" />
  </ItemGroup>

</Project>
